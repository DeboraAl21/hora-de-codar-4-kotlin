fun main() {

    // 1 - Estudantes.
    //Crie um programa onde o usuário possa cadastrar estudantes
    // sem limites, e, em seguida, Se o usuário digitar "PARE" o programa deve exibir a quantidade de
    // estudantes cadastrados e a lista com cada um deles.
    val lista = mutableListOf<String>()

    while (true) {
        print("Cadatre um aluno (ou 'PARE' para parar): ")
        val entrada = readln()

        if (entrada.lowercase() == "pare") break  // CORREÇÃO

        lista.add(entrada)  // guarda na lista
    }


    println("\nTotal de estudantes cadastrados: ${lista.size}")
    println("Lista dos estudantes:")
    for (n in lista) {
        println(n)
    }
}
